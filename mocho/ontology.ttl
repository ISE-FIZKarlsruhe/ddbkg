###  http://purl.org/ontology/mo/interview
<http://purl.org/ontology/mo/interview> rdf:type owl:NamedIndividual ,
                                                 <http://purl.org/ontology/mo/ReleaseType> ;
                                        <http://purl.org/dc/elements/1.1/description> """
        Recording of the questioning of a person.
        This is a type of MusicalManifestation defined by the musical industry.
    """ ;
                                        <http://purl.org/dc/elements/1.1/title> "interview" ;
                                        rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/live
<http://purl.org/ontology/mo/live> rdf:type owl:NamedIndividual ,
                                            <http://purl.org/ontology/mo/ReleaseType> ;
                                   <http://purl.org/dc/elements/1.1/description> """
        A musical manifestation that was recorded live.
        This is a type of MusicalManifestation defined by the musical industry.""" ;
                                   <http://purl.org/dc/elements/1.1/title> "live" ;
                                   rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/official
<http://purl.org/ontology/mo/official> rdf:type owl:NamedIndividual ,
                                                <http://purl.org/ontology/mo/ReleaseStatus> ;
                                       <http://purl.org/dc/elements/1.1/description> "Any musical work or the expression of a musical work officially sanctioned by the artist and/or their corporate body." ;
                                       <http://purl.org/dc/elements/1.1/title> "official" ;
                                       rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/promotion
<http://purl.org/ontology/mo/promotion> rdf:type owl:NamedIndividual ,
                                                 <http://purl.org/ontology/mo/ReleaseStatus> ;
                                        <http://purl.org/dc/elements/1.1/description> "A giveaway musical work or the expression of a musical work intended to promote an upcoming official musical work or the expression of a musical work." ;
                                        <http://purl.org/dc/elements/1.1/title> "promotion" ;
                                        rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/remix
<http://purl.org/ontology/mo/remix> rdf:type owl:NamedIndividual ,
                                             <http://purl.org/ontology/mo/ReleaseType> ;
                                    <http://purl.org/dc/elements/1.1/description> """
        Musical manifestation that primarily contains remixed material.
        This is a type of MusicalManifestation defined by the musical industry.
    """ ;
                                    <http://purl.org/dc/elements/1.1/title> "remix" ;
                                    rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/single
<http://purl.org/ontology/mo/single> rdf:type owl:NamedIndividual ,
                                              <http://purl.org/ontology/mo/ReleaseType> ;
                                     <http://purl.org/dc/elements/1.1/description> "A single or record single is a type of release, typically a recording of two tracks. In most cases, the single is a song that is released separately from an album, but it can still appear on an album." ;
                                     <http://purl.org/dc/elements/1.1/title> "single" ;
                                     rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/soundtrack
<http://purl.org/ontology/mo/soundtrack> rdf:type owl:NamedIndividual ,
                                                  <http://purl.org/ontology/mo/ReleaseType> ;
                                         <http://purl.org/dc/elements/1.1/description> """
        Sound recording on a narrow strip of a motion picture film.
        This is a type of MusicalManifestation defined by the musical industry.
    """ ;
                                         <http://purl.org/dc/elements/1.1/title> "soundtrack" ;
                                         rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/ontology/mo/spokenword
<http://purl.org/ontology/mo/spokenword> rdf:type owl:NamedIndividual ,
                                                  <http://purl.org/ontology/mo/ReleaseType> ;
                                         <http://purl.org/dc/elements/1.1/description> """
        Spoken word is a form of music or artistic performance in which lyrics, poetry, or stories are spoken rather than sung.
        Spoken-word is often done with a musical background, but emphasis is kept on the speaker.
        This is a type of MusicalManifestation defined by the musical industry.
    """ ;
                                         <http://purl.org/dc/elements/1.1/title> "spoken word" ;
                                         rdfs:isDefinedBy <http://purl.org/ontology/mo/> .


###  http://purl.org/spar/fabio/analog-magnetic-tape
<http://purl.org/spar/fabio/analog-magnetic-tape> rdf:type owl:NamedIndividual ,
                                                           <http://purl.org/spar/fabio/AnalogStorageMedium> ;
                                                  rdfs:comment "An analog medium for magnetic recording of audio and video information, made of a thin magnetizable coating on a long, narrow plastic tape, typically wound on a spool. "@en ;
                                                  rdfs:label "analog magnetic tape"@en .


###  http://purl.org/spar/fabio/cd
<http://purl.org/spar/fabio/cd> rdf:type owl:NamedIndividual ,
                                         <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                rdfs:comment "A non-rewritable optical disc used to store digital data."@en ;
                                rdfs:label "CD"@en ,
                                           "compact disk"@en .


###  http://purl.org/spar/fabio/cloud
<http://purl.org/spar/fabio/cloud> rdf:type owl:NamedIndividual ,
                                            <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                   rdfs:comment "A distributed and commoditized Internet-based computing resource, whereby shared services, software programs, and information storage facilities are provided to computers and other devices on demand, at locations of which the user may be unaware, like the electricity grid."@en ;
                                   rdfs:label "cloud" .


###  http://purl.org/spar/fabio/digital-magnetic-tape
<http://purl.org/spar/fabio/digital-magnetic-tape> rdf:type owl:NamedIndividual ,
                                                            <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                                   rdfs:comment "A rewritable digital medium for magnetic recording of audio, video and other data, made of a thin magnetizable coating on a long, narrow strip of plastic, usually wound on a spool."@en ;
                                                   rdfs:label "digital magnetic tape"@en .


###  http://purl.org/spar/fabio/dvd
<http://purl.org/spar/fabio/dvd> rdf:type owl:NamedIndividual ,
                                          <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                 rdfs:comment "A non-rewritable optical disc storage medium resembling a compact disc (CD), usually used for video and data storage. A DVD has the same physical dimensions as a CD, but is capable of storing more than six times as much data."@en ;
                                 rdfs:label "digital versatile disc"@en ,
                                            "digital video disc"@en ,
                                            "DVD" .


###  http://purl.org/spar/fabio/film
<http://purl.org/spar/fabio/film> rdf:type owl:NamedIndividual ,
                                           <http://purl.org/spar/fabio/AnalogStorageMedium> ;
                                  rdfs:comment "A thin flexible strip of plastic or other material coated with light-sensitive emulsion upon which images can be recorded, typically using a camera, usually used to record photographic images or motion pictures."@en ;
                                  rdfs:label "film"@en .


###  http://purl.org/spar/fabio/floppy-disk
<http://purl.org/spar/fabio/floppy-disk> rdf:type owl:NamedIndividual ,
                                                  <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                         rdfs:comment "A rewritable data storage medium that is composed of a disk of thin, flexible (floppy) magnetic storage medium encased in a square or rectangular  plastic shell.  Data are encoded magnetically by a read/write head that float on a cushion of air in close proximity to the surface of the rotated disk."@en ;
                                         rdfs:label "floppy disk"@en .


###  http://purl.org/spar/fabio/hard-drive
<http://purl.org/spar/fabio/hard-drive> rdf:type owl:NamedIndividual ,
                                                 <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                        rdfs:comment "A non-volatile storage device for digital data, composed of one or more rigid discs (platters) mounted side by side on a motor-driven spindle within a metal case. Data are encoded magnetically by read/write heads that float on cushions of air in close proximity to the surfaces of the rotated platters."@en ;
                                        rdfs:label "HD"@en ,
                                                   "hard drive"@en .


###  http://purl.org/spar/fabio/internet
<http://purl.org/spar/fabio/internet> rdf:type owl:NamedIndividual ,
                                               <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                      rdfs:comment "A global system of interconnected computer networks that uses the standard Internet Protocol Suite (TCP/IP) to serve billions of users worldwide.  The internet connects millions of private, public, academic, business and governmental computers, that are individually attached to local networks linked together by a broad array of electronic, radio and optical networking technologies to form the internet. "@en ;
                                      rdfs:label "internet"@en .


###  http://purl.org/spar/fabio/intranet
<http://purl.org/spar/fabio/intranet> rdf:type owl:NamedIndividual ,
                                               <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                      rdfs:comment "A private computer network, unconnected to the internet or separated from it by a firewall,  that uses a network operating system and Internet Protocol technologies to permit an organization's information to be shared securely within that organization."@en ;
                                      rdfs:label "intranet" .


###  http://purl.org/spar/fabio/paper
<http://purl.org/spar/fabio/paper> rdf:type owl:NamedIndividual ,
                                            <http://purl.org/spar/fabio/AnalogStorageMedium> ;
                                   rdfs:comment "A thin flat material, typically made from wood pulp, mainly used for writing upon, for printing upon or for packaging."@en ;
                                   rdfs:label "paper" .


###  http://purl.org/spar/fabio/ram
<http://purl.org/spar/fabio/ram> rdf:type owl:NamedIndividual ,
                                          <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                 rdfs:comment "Abbreviation of Random Access Memory.  A form of rewritable computer data storage that takes the form of integrated circuits that allow data to be stored and accessed in any order (i.e. at random), thereby achieving greater speed than for access of data stored in linear form on digital magnetic tape."@en ;
                                 rdfs:label "RAM"@en ,
                                            "random access memory"@en .


###  http://purl.org/spar/fabio/solid-state-memory
<http://purl.org/spar/fabio/solid-state-memory> rdf:type owl:NamedIndividual ,
                                                         <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                                rdfs:comment "A digital storage device built entirely from solid electronic materials with no moving parts, e.g. a USB flash drive."@en ;
                                                rdfs:label "solid state memory"@en .


###  http://purl.org/spar/fabio/vinyl-disk
<http://purl.org/spar/fabio/vinyl-disk> rdf:type owl:NamedIndividual ,
                                                 <http://purl.org/spar/fabio/AnalogStorageMedium> ;
                                        rdfs:comment "An analog sound storage medium consisting of a flat disc made of moulded vinyl plastic with an inscribed, modulated spiral groove."@en ;
                                        rdfs:label "vinyl disk"@en .


###  http://purl.org/spar/fabio/web
<http://purl.org/spar/fabio/web> rdf:type owl:NamedIndividual ,
                                          <http://purl.org/spar/fabio/DigitalStorageMedium> ;
                                 rdfs:comment "A system of interlinked hypertext documents written in HTML and accessed using the HTTP protocol via the Internet."@en ;
                                 rdfs:label "WWW"@en ,
                                            "Web"@en ,
                                            "World Wide Web"@en .


