    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Group"/>
    


    <!-- http://xmlns.com/foaf/0.1/Organization -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Organization"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://ise-fizkarlsruhe.github.io/ddbkg/mocho#Agent -->


    <owl:Class rdf:about="https://ise-fizkarlsruhe.github.io/ddbkg/mocho#Agent">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/terms/Agent"/>
        <rdfs:subClassOf rdf:resource="http://purl.org/vocab/frbr/core#ResponsibleEntity"/>
        <rdfs:subClassOf rdf:resource="http://rdaregistry.info/Elements/c/C10002"/>
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/Agent"/>
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:subClassOf rdf:resource="https://www.ica.org/standards/RiC/ontology#Agent"/>
        <rdfs:label xml:lang="en">mocho:Agent</rdfs:label>
