        <rdfs:label xml:lang="en">edm:hasMet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.europeana.eu/schemas/edm/isRelatedTo -->


    <owl:ObjectProperty rdf:about="http://www.europeana.eu/schemas/edm/isRelatedTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.europeana.eu/schemas/edm/ProvidedCHO"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.openarchives.org/ore/terms/Proxy"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.openarchives.org/ore/terms/proxyFor"/>
                                <owl:someValuesFrom rdf:resource="http://www.europeana.eu/schemas/edm/ProvidedCHO"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:label xml:lang="en">edm:isRelatedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.europeana.eu/schemas/edm/occurredAt -->


    <owl:ObjectProperty rdf:about="http://www.europeana.eu/schemas/edm/occurredAt">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/elements/1.1/relation"/>
        <rdfs:domain rdf:resource="http://www.europeana.eu/schemas/edm/Event"/>
        <rdfs:range rdf:resource="http://www.europeana.eu/schemas/edm/TimeSpan"/>
        <rdfs:label xml:lang="en">edm:occurredAt</rdfs:label>
    </owl:ObjectProperty>
    


