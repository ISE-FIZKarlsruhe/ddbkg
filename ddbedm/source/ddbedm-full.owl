    <!-- http://purl.org/dc/terms/LinguisticSystem -->

    <owl:Class rdf:about="http://purl.org/dc/terms/LinguisticSystem">
        <rdfs:comment xml:lang="en">Written, spoken, sign, and computer languages are linguistic systems.</rdfs:comment>
        <rdfs:label xml:lang="en">dcterms:LinguisticSystem</rdfs:label>
        <skos:definition xml:lang="en">A system of signs, symbols, sounds, gestures, or rules used in communication.</skos:definition>
    </owl:Class>
    


