        <owl:equivalentClass rdf:resource="http://www.europeana.eu/schemas/edm/InformationResource"/>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/Agent -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/Agent">
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/NonInformationResource"/>
        <rdfs:label xml:lang="en">edm:Agent</rdfs:label>
        <skos:example>Leonardo da Vinci, the British Museum, W3C</skos:example>
        <skos:example xml:lang="en">Leonardo da Vinci, the British Museum, W3C</skos:example>
        <skos:scopeNote>Rationale: This class is a domain of edm:wasPresentAt</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Rationale: This class is a domain of edm:wasPresentAt</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/EuropeanaAggregation -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/EuropeanaAggregation">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.europeana.eu/schemas/edm/aggregatedCHO"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/EuropeanaObject"/>
        <rdfs:subClassOf rdf:resource="http://www.openarchives.org/ore/terms/Aggregation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.europeana.eu/schemas/edm/aggregatedCHO"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Europeana Aggregation</rdfs:label>
        <skos:example xml:lang="en">The 56th issue of &quot;Le Temps&quot; is a (different) Cultural Heritage Object represented in Europeana by another EuropeanaAggregation instance</skos:example>
        <skos:example xml:lang="en">The journal &quot;Le Temps&quot; is a Cultural Heritage Object represented in Europeana by one EuropeanaAggregation instance</skos:example>
        <skos:example xml:lang="en">The painting Mona Lisa is a Cultural Heritage Object represented in Europeana by one EuropeanaAggregation instance</skos:example>
        <skos:note xml:lang="en">An instance of EuropeanaAggregation is created at ingestion time for each different Cultural Heritage Object recognized by Europeana. Such instance is associated to the Cultural Heritage Object that it is about, by the property edm:aggregatedCHO</skos:note>
        <skos:scopeNote xml:lang="en">Obligation and Occurence: The relation between the Cultural Heritage Objects represented in Europeana and the instances of the class EuropeanaAggregation is one-to-one, in the data maintained by Europeana: every Cultural Heritage Object is represented by an instance of EuropeanaAggregation, and every instance of EuropeanaAggregation represent a Cultural Heritage Object.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">Rationale: This class is used in Europeana to gather in a single conceptual unit all the information about a Cultural Heritage Object, necessary for all operations on these objects.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/EuropeanaObject -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/EuropeanaObject">
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/WebResource"/>
        <rdfs:label xml:lang="en">Europeana Object</rdfs:label>
        <skos:example xml:lang="en">An annotation created by a user through the Europeana portal</skos:example>
        <skos:example xml:lang="en">Any content created by the users through the service made available by Europeana for that purpose</skos:example>
        <skos:example xml:lang="en">Any instance of the class EuropeanaAggregation</skos:example>
        <skos:scopeNote xml:lang="en">Rationale: This class is used to tag objects that are the result of activity of Europeana, and, as such, objects on which Europeana holds rights</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/Event -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/Event">
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/NonInformationResource"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.europeana.eu/schemas/edm/happenedAt"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.europeana.eu/schemas/edm/happenedAt"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">edm:Event</rdfs:label>
        <skos:example xml:lang="en">The 2nd World War, the act of painting Mona Lisa, the change of custody of Mona Lisa.</skos:example>
        <skos:example xml:lang="en">the 2nd World War</skos:example>
        <skos:example xml:lang="en">the act of painting Mona Lisa</skos:example>
        <skos:example xml:lang="en">the change of custody of Mona Lisa</skos:example>
        <skos:note xml:lang="en">Events are identified either by the content provider or by Europeana enrichment at ingestion time</skos:note>
        <skos:scopeNote xml:lang="en">Rationale:This class is a domain of edm:happenedAt and the domain of edm:occurredAt</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/InformationResource -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/InformationResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://iflastandards.info/ns/fr/frbr/frbroo/F1_Work"/>
                    <rdf:Description rdf:about="http://iflastandards.info/ns/fr/frbr/frbroo/F2_Expression"/>
                    <rdf:Description rdf:about="http://iflastandards.info/ns/fr/frbr/frbroo/F3_Manifestation_Product_Type"/>
                    <rdf:Description rdf:about="http://iflastandards.info/ns/fr/frbr/frbroo/F4_Manifestation_Singleton"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/vocab/frbr/core#Expression"/>
                    <rdf:Description rdf:about="http://purl.org/vocab/frbr/core#Manifestation"/>
                    <rdf:Description rdf:about="http://purl.org/vocab/frbr/core#Work"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="en">edm:InformationResource</rdfs:label>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/NonInformationResource -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/NonInformationResource">
        <owl:equivalentClass>
            <owl:Class>
                <owl:complementOf rdf:resource="http://www.europeana.eu/schemas/edm/InformationResource"/>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="en">edm:NonInformationResource</rdfs:label>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/PhysicalThing -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/PhysicalThing">
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/NonInformationResource"/>
        <rdfs:label xml:lang="en">edm:PhysicalThing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/Place -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/Place">
        <owl:equivalentClass rdf:resource="http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl#space-region"/>
        <rdfs:subClassOf rdf:resource="http://www.europeana.eu/schemas/edm/NonInformationResource"/>
        <rdfs:label xml:lang="en">edm:Place</rdfs:label>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/ProvidedCHO -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/ProvidedCHO">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://www.europeana.eu/schemas/edm/aggregatedCHO"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://www.europeana.eu/schemas/edm/aggregatedCHO"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">edm:ProvidedCHO</rdfs:label>
        <skos:example xml:lang="en">Mona Lisa, Winged Victory of Samothrace</skos:example>
        <skos:note xml:lang="en">This class has been mostly motivated by the need to assign a type to the “central node” in the EDM pattern, during the ingestion process, related to the XML expression of EDM at that stage. It was especially intended to fit the cases where edm:PhysicalThing  cannot be used as the type of the resource standing for the real-world object (independently of any specific data contributor perspective).</skos:note>
        <skos:scopeNote xml:lang="en">Rationale: This class is the range of edm:aggregatedCHO. A resource of type ProvidedCHO can be the subject of statements using edm:isRelatedTo or any more specific property.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.europeana.eu/schemas/edm/TimeSpan -->

    <owl:Class rdf:about="http://www.europeana.eu/schemas/edm/TimeSpan">
        <owl:equivalentClass rdf:resource="http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl#time-interval"/>
