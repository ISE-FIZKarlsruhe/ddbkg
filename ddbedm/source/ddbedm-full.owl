    <!-- http://europeana.eu -->

    <owl:NamedIndividual rdf:about="http://europeana.eu">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    </owl:NamedIndividual>
    


    <!-- http://data.semanticweb.org/person/antoine-isaac -->

    <owl:NamedIndividual rdf:about="http://data.semanticweb.org/person/antoine-isaac">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    </owl:NamedIndividual>
    


    <!-- http://www.europeana.eu/schemas/edm/ -->

    <owl:NamedIndividual rdf:about="http://www.europeana.eu/schemas/edm/">
        <rdf:type rdf:resource="http://purl.org/vocommons/voaf#Vocabulary"/>
        <dc:contributor rdf:resource="http://www.ibi.hu-berlin.de/institut/personen/iwanowa"/>
        <dc:contributor rdf:resource="http://www.ics.forth.gr/isl/people/people_individual.jsp?Person_ID=2"/>
        <dc:contributor rdf:resource="http://www.image.ece.ntua.gr/~ndroso/"/>
        <dc:contributor rdf:resource="http://www.image.ntua.gr/~tzouvaras/"/>
        <dc:contributor>
            <rdf:Description>
