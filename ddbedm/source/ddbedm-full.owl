        <skos:definition xml:lang="en">A physical material or carrier.</skos:definition>
        <skos:example xml:lang="en">Examples include paper, canvas, or DVD.</skos:example>
    </owl:Class>
    


    <!-- http://purl.org/dc/terms/PhysicalResource -->

    <owl:Class rdf:about="http://purl.org/dc/terms/PhysicalResource">
